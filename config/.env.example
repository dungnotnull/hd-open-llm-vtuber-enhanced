# ===========================================================================
# open-llm-vtuber-enhanced — environment variables
# Copy to .env and fill in. Never commit real keys.
# ===========================================================================

# ----- LLM providers (at least one recommended; Ollama needs no key) -------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# Force the local Ollama provider for fully offline / privacy mode.
PRIVACY_MODE=false

# ----- HuggingFace ----------------------------------------------------------
# Needed to download gated models such as pyannote/speaker-diarization-3.1.
HF_TOKEN=hf_...
HF_HOME=./models

# ----- runtime --------------------------------------------------------------
LOG_LEVEL=INFO
VTUBER_PORT=8001

# ----- optional voice cloning reference -------------------------------------
# Path to a 6-second clean WAV used by XTTS-v2 for zero-shot voice cloning.
REFERENCE_VOICE_WAV=
